@@ -0,0 +1,407 @@
+package org.telegram.messenger;
+
+import android.content.Context;
+import android.content.SharedPreferences;
+import android.util.Log;
+import android.widget.Toast;
+
+import org.telegram.tgnet.ConnectionsManager;
+
+import java.io.File;
+import java.io.FileOutputStream;
+import java.io.IOException;
+import java.io.InputStream;
+import java.io.OutputStream;
+import java.net.InetSocketAddress;
+import java.net.Socket;
+import java.util.concurrent.TimeUnit;
+
+public class XrayLauncher {
+    private static final String TAG = "XrayLauncher";
+    private static volatile Process xrayProcess;
+    private static final int LOCAL_SOCKS_PORT = 10808;
+    private static final int SOCKS_READY_TIMEOUT_MS = 20000;
+    private static final int SOCKS_RETRY_STEP_MS = 250;
+    private static Thread stdoutThread;
+    private static Thread stderrThread;
+    private static final Object lock = new Object();
+
+    private static void logd(String msg) {
+        FileLog.d("XrayLauncher: " + msg);
+        Log.d(TAG, msg);
+    }
+
+    private static void loge(String msg) {
+        FileLog.e("XrayLauncher: " + msg);
+        Log.e(TAG, msg);
+    }
+
+    public static void start(Context context) {
+        try {
+            synchronized (lock) {
+                if (xrayProcess != null && xrayProcess.isAlive()) {
+                    logd("start skipped, already running");
+                    Log.i(TAG, "Xray already running");
+                    return;
+                }
+
+            File filesDir = context.getFilesDir();
+
+            String assetCandidate;
+            String primaryAbi = "";
+            try {
+                String[] abis = android.os.Build.SUPPORTED_ABIS;
+                if (abis != null && abis.length > 0) primaryAbi = abis[0];
+            } catch (Throwable t) {
+                Log.w(TAG, "Failed to get SUPPORTED_ABIS", t);
+            }
+
+            if (primaryAbi.contains("arm64")) assetCandidate = "xray-arm64-v8a";
+            else if (primaryAbi.contains("armeabi") || primaryAbi.contains("arm")) assetCandidate = "xray-armv7";
+            else if (primaryAbi.contains("x86_64") || primaryAbi.contains("amd64") || primaryAbi.contains("x86")) assetCandidate = "xray-amd64";
+            else assetCandidate = "xray";
+            logd("detected abi=" + primaryAbi + ", preferred asset=" + assetCandidate);
+
+            File bin = resolveExecutableBinary(context, filesDir, assetCandidate);
+            if (bin == null) {
+                loge("no runnable xray binary found");
+                showUnsupportedAbiMessage(context, primaryAbi);
+                return;
+            }
+
+            File config = new File(filesDir, "config.json");
+            boolean copiedConfig = false;
+            try {
+                // Always refresh config from assets to avoid stale config after app updates.
+                copyAssetToFile(context, "config.json", config);
+                copiedConfig = true;
+                logd("using config asset: config.json");
+            } catch (Exception ex) {
+                FileLog.e(ex);
+                Log.w(TAG, "config.json not found in assets, trying xray_config.json", ex);
+            }
+
+            if (!copiedConfig) {
+                try {
+                    copyAssetToFile(context, "xray_config.json", config);
+                    copiedConfig = true;
+                    logd("using fallback config asset: xray_config.json");
+                } catch (Exception ex) {
+                    FileLog.e(ex);
+                    Log.e(TAG, "No config asset found (config.json/xray_config.json)", ex);
+                }
+            }
+
+            if (!copiedConfig) {
+                loge("failed to load any config asset");
+                return;
+            }
+
+            // Geo databases are required for configs with geosite/geoip rules.
+            prepareGeoAssets(context, filesDir);
+
+            String[] cmd = new String[]{bin.getAbsolutePath(), "-config", config.getAbsolutePath()};
+            try {
+                ProcessBuilder pb = new ProcessBuilder(cmd);
+                pb.directory(filesDir);
+                pb.environment().put("XRAY_LOCATION_ASSET", filesDir.getAbsolutePath());
+                pb.redirectErrorStream(false);
+                Process proc = pb.start();
+                xrayProcess = proc;
+                logd("process started: " + bin.getAbsolutePath() + " -config " + config.getAbsolutePath());
+
+                // start gobblers
+                stdoutThread = startGobbler(proc.getInputStream(), TAG + ":stdout");
+                stderrThread = startGobbler(proc.getErrorStream(), TAG + ":stderr");
+
+                Thread applyProxyThread = new Thread(() -> {
+                    try {
+                        if (waitForLocalSocksReady(SOCKS_READY_TIMEOUT_MS)) {
+                            enableLocalProxy();
+                            logd("local SOCKS ready, proxy enabled");
+                        } else {
+                            loge("local SOCKS 127.0.0.1:" + LOCAL_SOCKS_PORT + " not ready");
+                        }
+                    } catch (Throwable e) {
+                        FileLog.e(e);
+                    }
+                });
+                applyProxyThread.setDaemon(true);
+                applyProxyThread.start();
+
+                // If xray exits, keep saved proxy preference and ask networking layer to re-ensure Xray.
+                Thread monitor = new Thread(() -> {
+                    try {
+                        int code = proc.waitFor();
+                        synchronized (lock) {
+                            if (xrayProcess == proc) {
+                                xrayProcess = null;
+                                stdoutThread = null;
+                                stderrThread = null;
+                            }
+                        }
+                        for (int a = 0; a < UserConfig.MAX_ACCOUNT_COUNT; a++) {
+                            try {
+                                ConnectionsManager.getInstance(a).checkConnection();
+                            } catch (Throwable t) {
+                                FileLog.e(t);
+                            }
+                        }
+                        loge("process exited with code " + code);
+                    } catch (InterruptedException ignored) {
+                        Thread.currentThread().interrupt();
+                    } catch (Throwable t) {
+                        FileLog.e(t);
+                        Log.w(TAG, "Xray monitor thread failed", t);
+                    }
+                });
+                monitor.setDaemon(true);
+                monitor.start();
+
+                Log.i(TAG, "Xray started with cmd: " + bin.getAbsolutePath());
+            } catch (Throwable e) {
+                FileLog.e(e);
+                loge("cannot start xray process");
+                Log.e(TAG, "Cannot start xray", e);
+            }
+            }
+        } catch (Throwable t) {
+            FileLog.e(t);
+            loge("fatal error in start(), xray disabled for current launch");
+        }
+    }
+
+    private static File resolveExecutableBinary(Context context, File filesDir, String assetCandidate) {
+        try {
+            String nativeDir = context.getApplicationInfo().nativeLibraryDir;
+            if (nativeDir != null) {
+                File nativeBin = new File(nativeDir, "libxrayexec.so");
+                if (nativeBin.exists() && nativeBin.canExecute()) {
+                    logd("using nativeLibraryDir binary: " + nativeBin.getAbsolutePath());
+                    return nativeBin;
+                }
+            }
+        } catch (Throwable t) {
+            FileLog.e(t);
+        }
+
+        // Fallback for environments where bundled native binary is unavailable.
+        File bin = new File(filesDir, "xray");
+        boolean copied = false;
+        String[] tryNames = new String[]{assetCandidate, "xray", "xray-arm64-v8a", "xray-armv7", "xray-amd64"};
+        for (String name : tryNames) {
+            try {
+                if (!bin.exists() || !bin.canExecute()) {
+                    File tmp = new File(filesDir, "xray.tmp");
+                    copyAssetToFile(context, name, tmp);
+                    boolean execSet = tmp.setExecutable(true, false);
+                    if (!execSet) {
+                        tryChmod(tmp.getAbsolutePath());
+                    }
+                    if (bin.exists()) {
+                        bin.delete();
+                    }
+                    if (!tmp.renameTo(bin) && tmp.exists()) {
+                        tmp.renameTo(bin);
+                    }
+                }
+                if (!bin.canExecute()) {
+                    boolean execSet2 = bin.setExecutable(true, false);
+                    if (!execSet2) {
+                        tryChmod(bin.getAbsolutePath());
+                    }
+                }
+                copied = bin.exists() && bin.canExecute();
+                if (copied) {
+                    logd("using filesDir fallback binary: " + bin.getAbsolutePath());
+                    break;
+                }
+            } catch (Exception ex) {
+                FileLog.e(ex);
+                Log.w(TAG, "failed to copy xray asset: " + name, ex);
+            }
+        }
+
+        return copied ? bin : null;
+    }
+
+    public static void stop() {
+        synchronized (lock) {
+            if (xrayProcess == null) return;
+            try {
+                xrayProcess.destroy();
+                if (!xrayProcess.waitFor(5, TimeUnit.SECONDS)) {
+                    xrayProcess.destroyForcibly();
+                }
+            } catch (Throwable t) {
+                try {
+                    xrayProcess.destroyForcibly();
+                } catch (Throwable ignored) {
+                }
+            }
+
+            // join gobbler threads
+            try {
+                if (stdoutThread != null) stdoutThread.join(2000);
+            } catch (InterruptedException ignored) {
+                Thread.currentThread().interrupt();
+            }
+            try {
+                if (stderrThread != null) stderrThread.join(2000);
+            } catch (InterruptedException ignored) {
+                Thread.currentThread().interrupt();
+            }
+
+            stdoutThread = null;
+            stderrThread = null;
+            xrayProcess = null;
+            try {
+                disableLocalProxy();
+            } catch (Throwable ignored) {
+            }
+        }
+    }
+
+    public static void ensureLocalProxyProfile() {
+        try {
+            SharedConfig.addProxy(new SharedConfig.ProxyInfo("127.0.0.1", LOCAL_SOCKS_PORT, "", "", ""));
+        } catch (Throwable t) {
+            FileLog.e(t);
+        }
+    }
+
+    private static void enableLocalProxy() {
+        SharedConfig.ProxyInfo info = new SharedConfig.ProxyInfo("127.0.0.1", LOCAL_SOCKS_PORT, "", "", "");
+        SharedConfig.currentProxy = SharedConfig.addProxy(info);
+
+        SharedPreferences.Editor editor = MessagesController.getGlobalMainSettings().edit();
+        editor.putString("proxy_ip", SharedConfig.currentProxy.address);
+        editor.putInt("proxy_port", LOCAL_SOCKS_PORT);
+        editor.putString("proxy_user", "");
+        editor.putString("proxy_pass", "");
+        editor.putString("proxy_secret", "");
+        editor.putBoolean("proxy_enabled", true);
+        editor.putBoolean("proxy_enabled_calls", false);
+        editor.apply();
+
+        ConnectionsManager.setProxySettings(true, "127.0.0.1", LOCAL_SOCKS_PORT, "", "", "");
+        logd("setProxySettings enabled 127.0.0.1:" + LOCAL_SOCKS_PORT);
+        for (int a = 0; a < UserConfig.MAX_ACCOUNT_COUNT; a++) {
+            try {
+                ConnectionsManager.getInstance(a).checkConnection();
+            } catch (Throwable t) {
+                FileLog.e(t);
+            }
+        }
+        NotificationCenter.getGlobalInstance().postNotificationName(NotificationCenter.proxySettingsChanged);
+    }
+
+    private static void disableLocalProxy() {
+        SharedPreferences.Editor editor = MessagesController.getGlobalMainSettings().edit();
+        editor.putBoolean("proxy_enabled", false);
+        editor.apply();
+
+        ConnectionsManager.setProxySettings(false, "", 0, "", "", "");
+        logd("setProxySettings disabled");
+        NotificationCenter.getGlobalInstance().postNotificationName(NotificationCenter.proxySettingsChanged);
+    }
+
+    private static boolean waitForLocalSocksReady(int timeoutMs) {
+        long deadline = System.currentTimeMillis() + timeoutMs;
+        while (System.currentTimeMillis() < deadline) {
+            synchronized (lock) {
+                if (xrayProcess == null || !xrayProcess.isAlive()) {
+                    return false;
+                }
+            }
+            try (Socket socket = new Socket()) {
+                socket.connect(new InetSocketAddress("127.0.0.1", LOCAL_SOCKS_PORT), 250);
+                return true;
+            } catch (IOException ignored) {
+                try {
+                    Thread.sleep(SOCKS_RETRY_STEP_MS);
+                } catch (InterruptedException e) {
+                    Thread.currentThread().interrupt();
+                    return false;
+                }
+            }
+        }
+        return false;
+    }
+
+    private static void copyAssetToFile(Context context, String assetName, File outFile) throws Exception {
+        try (InputStream is = context.getAssets().open(assetName); OutputStream os = new FileOutputStream(outFile)) {
+            byte[] buf = new byte[8192];
+            int r;
+            while ((r = is.read(buf)) != -1) {
+                os.write(buf, 0, r);
+            }
+            os.flush();
+        }
+    }
+
+    private static void prepareGeoAssets(Context context, File filesDir) {
+        copyOptionalAsset(context, "geoip.dat", new File(filesDir, "geoip.dat"));
+        copyOptionalAsset(context, "geosite.dat", new File(filesDir, "geosite.dat"));
+    }
+
+    private static void copyOptionalAsset(Context context, String assetName, File outFile) {
+        try {
+            copyAssetToFile(context, assetName, outFile);
+            logd("geo asset ready: " + assetName + " -> " + outFile.getAbsolutePath());
+        } catch (Throwable t) {
+            // Keep running for configs that do not require geo files.
+            logd("optional asset missing: " + assetName);
+        }
+    }
+
+    private static void tryChmod(String path) {
+        try {
+            Process p = Runtime.getRuntime().exec(new String[]{"chmod", "755", path});
+            p.waitFor(3, TimeUnit.SECONDS);
+            try {
+                p.getInputStream().close();
+            } catch (IOException ignored) {
+            }
+            try {
+                p.getErrorStream().close();
+            } catch (IOException ignored) {
+            }
+        } catch (Throwable e) {
+            Log.w(TAG, "chmod failed for " + path, e);
+        }
+    }
+
+    private static void showUnsupportedAbiMessage(Context context, String abi) {
+        AndroidUtilities.runOnUIThread(() -> {
+            try {
+                String template = LocaleController.getString(R.string.XrayUnsupportedAbiToast);
+                String message = String.format(template, abi == null || abi.isEmpty() ? "unknown" : abi);
+                Toast.makeText(context, message, Toast.LENGTH_LONG).show();
+            } catch (Throwable t) {
+                FileLog.e(t);
+            }
+        });
+    }
+
+    private static Thread startGobbler(final InputStream is, final String tag) {
+        Thread t = new Thread(() -> {
+            try (InputStream in = is) {
+                byte[] buf = new byte[4096];
+                int r;
+                while ((r = in.read(buf)) != -1) {
+                    // drop or log small chunks to avoid OOM; here just log at debug
+                    String chunk = new String(buf, 0, r);
+                    FileLog.d(tag + " " + chunk);
+                    Log.d(tag, chunk);
+                }
+            } catch (IOException e) {
+                FileLog.e(e);
+                Log.w(tag, "gobbler error", e);
+            }
+        });
+        t.setDaemon(true);
+        t.start();
+        return t;
+    }
+}
